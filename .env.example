# Token from @BotFather (https://t.me/BotFather -> /newbot)
BOT_TOKEN=123456789:AA...your-token-here

# Chat that receives applications.
# For a private chat: your numeric user id (get it from @userinfobot).
# For a group: add the bot to the group, then use the group's id (starts with -100...).
ADMIN_CHAT_ID=123456789

# Optional: Google Apps Script web app URL (see google-apps-script.gs).
# When set, every application is also appended as a row in your Google Sheet.
#SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/.../exec
